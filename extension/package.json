{
  "name": "lux-extension",
  "version": "0.1.5",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "build:prepare": "bun run scripts/prepare.ts",
    "zip": "wxt zip",
    "postinstall": "wxt prepare",
    "check": "vue-tsc --noEmit",
    "pack:crx": "crx3 .output/chrome-mv3 -p ./key.pem -o lux-extension.crx",
    "fmt": "oxfmt src entrypoints *.ts"
  },
  "dependencies": {
    "tdesign-vue-next": "^1.19.1",
    "vue": "^3.5.33",
    "vue-tsc": "^3.2.7"
  },
  "devDependencies": {
    "@wxt-dev/module-vue": "^1.0.3",
    "crx3": "^2.0.0",
    "wxt": "^0.20.25"
  }
}
